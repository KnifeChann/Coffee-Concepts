# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong random secret for production:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_in_production

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# Railway / Render inject this automatically when you add the Postgres plugin.
# Local docker-compose default:
DATABASE_URL=postgresql://cc:cc_dev@localhost:5432/coffeeconcepts

# ─── Redis ────────────────────────────────────────────────────────────────────
# Railway / Render inject this automatically when you add the Redis plugin.
# Local docker-compose default:
REDIS_URL=redis://localhost:6379

# ─── Admin ───────────────────────────────────────────────────────────────────
# Comma-separated list of emails that get admin privileges on signup / server start.
ADMIN_EMAILS=

# ─── Optional: OpenWeatherMap ─────────────────────────────────────────────────
# Leave blank to use the free Open-Meteo fallback (no key needed).
WEATHER_API_KEY=
