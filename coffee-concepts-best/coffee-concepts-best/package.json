{
  "name": "coffee-concepts-best",
  "version": "2.0.0",
  "private": true,
  "description": "Coffee & Concepts Best — Aadhaar-verified study rooms. Production-ready: PostgreSQL (Prisma), Redis, Socket.IO Redis adapter, distributed timer worker.",
  "scripts": {
    "start":          "node server/index.js",
    "dev":            "node server/index.js",
    "timer":          "node server/timerWorker.js",
    "prisma:migrate": "npx prisma migrate deploy",
    "prisma:dev":     "npx prisma migrate dev",
    "prisma:studio":  "npx prisma studio"
  },
  "dependencies": {
    "@prisma/client":            "^5.13.0",
    "@socket.io/redis-adapter":  "^8.3.0",
    "bcryptjs":                  "^2.4.3",
    "cors":                      "^2.8.5",
    "dotenv":                    "^16.4.5",
    "express":                   "^4.21.2",
    "ioredis":                   "^5.3.2",
    "jsonwebtoken":              "^9.0.2",
    "socket.io":                 "^4.8.1",
    "uuid":                      "^11.0.3"
  },
  "devDependencies": {
    "prisma": "^5.13.0"
  }
}
